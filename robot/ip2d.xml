<mujoco model="robot_roll2d_locked">
  <!--
    原机器人二维约束工况（roll 平面）：
    - 只保留 y 方向平移 + 绕 x 轴侧倾（roll）
    - 舵角固定为沿 y 方向滚动（通过模块整体旋转 +90°）
    - 轮子用力矩控制，便于 LQR 直接输出控制量
    - 质量与几何参数来自当前 robot/robot.xml
  -->

  <compiler angle="radian" coordinate="local" inertiafromgeom="true" />
  <option timestep="0.001" gravity="0 0 -9.81" integrator="RK4" cone="elliptic" />

  <default>
    <!-- <joint damping="0.001" armature="0.0" /> -->
    <joint damping="1.0" armature="0.0" />
    <geom friction="0.9 0.01 0.0001" solref="0.02 1" solimp="0.9 0.95 0.002" />
    <!-- <joint damping="0.02" armature="0.002" />
    <geom friction="1.2 0.003 0.0001" solref="0.005 1" solimp="0.95 0.99 0.0005" /> -->
  </default>

  <asset>
    <texture name="tex_checker" type="2d" builtin="checker" width="512" height="512" rgb1="0.9 0.9 0.9" rgb2="0.6 0.6 0.6" />
    <material name="mat_ground" texture="tex_checker" texrepeat="4 4" texuniform="true" />
    <material name="mat_chassis" rgba="0.2 0.2 0.2 1" />
    <material name="mat_leg" rgba="0.2 0.5 0.9 1" />
    <material name="mat_wheel" rgba="0.05 0.05 0.05 1" />
    <material name="mat_servo" rgba="0.8 0.5 0.1 1" />
  </asset>

  <worldbody>
    <!-- 地面与相机 -->
    <geom name="ground" type="plane" size="30 30 0.1" rgba="0.92 0.92 0.92 1"  material="mat_ground" />
    <geom type="plane" size="10 10 0.1" solref="0.04 0.9" solimp="0.9 0.99 0.003" material="mat_ground"/>
    <light name="sun" pos="0 0 2" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" />
    <camera name="track" mode="trackcom" pos="0 -1.2 0.6" xyaxes="1 0 0 0 0 1" />

    <!--
      坐标系：x 向前，y 向左，z 向上
      这里把 roll 转轴放在轮-地接触附近（z≈0），更接近真实侧倾支点
    -->
    <body name="roll_base" pos="0 0 0">
      <!-- 二维约束：允许 y 平移 + z 自由落地 + roll -->
      <joint name="base_x" type="slide" axis="1 0 0" damping="0" armature="0" />
      <joint name="base_y" type="slide" axis="0 1 0" damping="0" armature="0" />
      <joint name="base_z" type="slide" axis="0 0 1" damping="0" armature="0" />
      <!-- <joint name="base_roll" type="hinge" axis="1 0 0" damping="0" armature="0" limited="true" range="-0.01 0.01"/> -->
      <joint name="base_yaw" type="hinge" axis="0 0 1" damping="0" armature="0" />
      <joint name="base_roll" type="hinge" axis="1 0 0" damping="0" armature="0"/>
      <joint name="base_pitch" type="hinge" axis="0 1 0" damping="0" armature="0" />
      <!-- <freejoint name="chassis_free" /> -->

      <!-- 机身主体（相对 roll_base 上移到原来的高度） -->
      <body name="chassis" pos="0 0 0.31">
        <geom
          name="chassis_geom"
          type="box"
          size="0.25 0.15 0.01"
          mass="6.87"
          material="mat_chassis" />

        <site name="ctrl_site" pos="0.15 0 0" size="0.01" rgba="0 1 0 1" />

        <!-- 前轮腿模块（整体绕 z 轴旋转 +90°，等效舵角锁定） -->
        <body name="left_module" pos="0.13 0 -0.02" euler="0 0 1.5708">
          <joint name="left_steer" type="hinge" axis="0 0 1" damping="0.3" frictionloss="0.1"/>
          <geom
            name="left_servo_geom"
            type="cylinder"
            size="0.1 0.01"
            mass="0.304"
            material="mat_servo" />

          <geom
            name="left_leg_geom"
            type="box"
            pos="0 0.02 -0.10"
            size="0.04 0.01 0.12"
            mass="5"
            material="mat_leg" />

          <body name="left_wheel" pos="0 0 -0.24">
            <joint name="left_wheel_spin" type="hinge" axis="0 1 0" damping="0.1" armature="0.00"/>
            <!-- <geom
              name="left_wheel_geom"
              type="cylinder"
              size="0.06 0.01"
              quat="0.7071068 0.7071068 0 0"
              mass="0.828"
              material="mat_wheel" /> -->
            <geom name="left_wheel_geom" type="sphere" size="0.06" friction="0.8 0.01 0.001"/>
            <!-- <geom name="left_wheel_visual" type="cylinder" size="0.06 0.01" contype="0" conaffinity="0" rgba="0.2 0.2 0.2 1" quat="0.7071068 0.7071068 0 0"
              mass="0.828"/> -->
          </body>
        </body>

        <!-- 后轮腿模块（整体绕 z 轴旋转 +90°，等效舵角锁定） -->
        <body name="right_module" pos="-0.13 0 -0.02" euler="0 0 1.5708">
          <joint name="right_steer" type="hinge" axis="0 0 1" damping="0.3" frictionloss="0.1" />
          <geom
            name="right_servo_geom"
            type="cylinder"
            size="0.1 0.01"
            mass="0.304"
            material="mat_servo" />

          <geom
            name="right_leg_geom"
            type="box"
            pos="0 0.02 -0.10"
            size="0.04 0.01 0.12"
            mass="5"
            material="mat_leg" />

          <body name="right_wheel" pos="0 0 -0.24">
            <joint name="right_wheel_spin" type="hinge" axis="0 1 0" damping="0.1" armature="0.00"/>
            <!-- <geom
              name="right_wheel_geom"
              type="cylinder"
              size="0.06 0.01"
              quat="0.7071068 0.7071068 0 0"
              mass="0.828"
              material="mat_wheel" /> -->
            <geom name="right_wheel_geom" type="sphere" size="0.06" friction="0.8 0.01 0.001"/>
            <!-- <geom name="right_wheel_visual" type="cylinder" size="0.06 0.01" contype="0" conaffinity="0" rgba="0.2 0.2 0.2 1" quat="0.7071068 0.7071068 0 0"
              mass="0.828"/> -->
          </body>
        </body>
      </body>
    </body>

  </worldbody>

  <actuator>
    <!-- 轮子力矩控制：LQR 输出可直接作为控制量 -->
    <motor name="left_wheel_tau" joint="left_wheel_spin" gear="1" ctrlrange="-8 8" />
    <motor name="right_wheel_tau" joint="right_wheel_spin" gear="1" ctrlrange="-8 8" />
    <!-- 舵角位置控制（swerve 用） -->
    <!-- <position name="left_steer_tau" joint="left_steer" kp="0" ctrlrange="-3.14 3.14" />
    <position name="right_steer_tau" joint="right_steer" kp="0" ctrlrange="-3.14 3.14" /> -->
    <motor name="left_steer_tau" joint="left_steer" gear="1" ctrlrange="-15 15" />
    <motor name="right_steer_tau" joint="right_steer" gear="1" ctrlrange="-15 15" />
  </actuator>
</mujoco>
